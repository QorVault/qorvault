# Open WebUI — Web-based chat interface
# ------------------------------------------------------------------
# Runs Open WebUI in a Podman container on port 3000. Provides a
# ChatGPT-like interface that connects to llama-server (port 8080)
# for conversation and the RAG API (port 8000) for BoardDocs search.
#
# Install to: ~/.config/systemd/user/container-open-webui.service
#
# Dependencies:
#   - ksd-llama-server must be running (provides the LLM backend)
#   - ksd-rag-api must be running (provides the RAG tool backend)
#   - Podman must be installed
#
# Enable and start:
#   systemctl --user daemon-reload
#   systemctl --user enable container-open-webui
#   systemctl --user start container-open-webui
#
# Verify:
#   curl -s http://localhost:3000 | head -1
#   # Should return HTML
# ------------------------------------------------------------------

# container-open-webui.service
# autogenerated by Podman 5.7.1
# Sun Feb  1 07:40:05 PST 2026

[Unit]
Description=Podman container-open-webui.service
Documentation=man:podman-generate-systemd(1)
Wants=network-online.target
After=network-online.target
RequiresMountsFor=%t/containers

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
TimeoutStopSec=70
ExecStart=/usr/bin/podman run \
	--cidfile=%t/%n.ctr-id \
	--cgroups=no-conmon \
	--rm \
	--sdnotify=conmon \
	--replace \
	-d \
	-p 3000:8080 \
	-v open-webui:/app/backend/data \
	-e WEBUI_SECRET_KEY=your-secret-key-here \
	--name open-webui \
	--label io.containers.autoupdate=registry ghcr.io/open-webui/open-webui:main
ExecStop=/usr/bin/podman stop \
	--ignore -t 10 \
	--cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm \
	-f \
	--ignore -t 10 \
	--cidfile=%t/%n.ctr-id
Type=notify
NotifyAccess=all

[Install]
WantedBy=default.target
